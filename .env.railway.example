# Neon (https://neon.tech) — pegá la connection string del dashboard
DATABASE_URL=postgresql://USER:PASS@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=cambiar-por-secreto-largo
NODE_ENV=production

# Build + runtime en Railway (Google Maps)
VITE_GOOGLE_MAPS_API_KEY=tu-google-maps-key

# Solo en el PRIMER deploy, después poné false
RUN_SEED=true
RUN_ADMIN=true
RUN_INSPECTORS=false
